# .env — Variables para servicios dentro del contenedor
#        Este archivo se carga desde entrypoint.sh dentro del container

# PostgreSQL (host del servicio en la red Docker)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Ollama
OLLAMA_HOST=http://ollama:11434

# OpenVAS
OPENVAS_HOST=openvas

# Directorios dentro del contenedor
TEMP_DIR=/app/temp
LOG_DIR=/app/logs
OUTPUT_DIR=/app/data
RESOURCE_DIR=/app/resources