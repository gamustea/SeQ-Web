# ──────────────────────────────────────────────────────────────────────────────
# .env.example  —  Variables de entorno para docker-compose
# ──────────────────────────────────────────────────────────────────────────────


# ── APP CONTEXT ────────────────────────────────────────────────────────────────
SHUTDOWN_TIMEOUT=30
CREATE_DATABASE=False
DEBUG=False
HOST=0.0.0.0
PORT=5000

# ── JWT ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key_here_min_32_chars_required
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY_MINUTES=30
REFRESH_TOKEN_EXPIRY_DAYS=7

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=your_database_name
POSTGRES_HOST=127.0.0.1
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_PORT=5432
POSTGRES_DIALECT=postgresql+psycopg2

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=production

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password_here

# ── OpenVAS ─────────────────────────────────────────────────────────────────────
OPENVAS_HOST=localhost
OPENVAS_USERNAME=your_openvas_username
OPENVAS_PASSWORD=your_secure_openvas_password_here
OPENVAS_PORT=9390

# ── OpenAI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
