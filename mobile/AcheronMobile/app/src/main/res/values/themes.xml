<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Tema base de la app: oscuro, sin barra de accion. El fondo de ventana
         es el abismo de marca para evitar el destello blanco en el arranque en
         frio antes de que Compose pinte. -->
    <style name="Theme.AcheronMobile" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/acheron_abyss</item>
        <item name="android:statusBarColor">@color/acheron_abyss</item>
        <item name="android:navigationBarColor">@color/acheron_abyss</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Pantalla de inicio (SplashScreen API, retrocompatible vía
         core-splashscreen): rio purpura de Acheron sobre el abismo. Reemplaza
         al splash automatico que usaba el icono del lanzador (lobo naranja). -->
    <style name="Theme.AcheronMobile.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/acheron_abyss</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_river</item>
        <item name="postSplashScreenTheme">@style/Theme.AcheronMobile</item>
    </style>
</resources>
